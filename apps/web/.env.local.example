# Supabase project URL — public, safe to commit
NEXT_PUBLIC_SUPABASE_URL=https://bdmcxciktsjqonyxnnen.supabase.co

# Supabase anon (public) key — paste from the Supabase dashboard.
# Goes in .env.local (which is gitignored). Do NOT commit.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only. Used for: public lead intake,
# invitation token verification, system jobs, integration handoff.
# Do NOT prefix with NEXT_PUBLIC_. Do NOT commit. Server-only env var.
SUPABASE_SERVICE_ROLE_KEY=

# Slug of the organisation that owns public lead submissions. Optional;
# defaults to 'social-plus' (the seeded pilot org). Override per-environment
# once we onboard a second provider.
# DEFAULT_ORGANISATION_SLUG=social-plus
