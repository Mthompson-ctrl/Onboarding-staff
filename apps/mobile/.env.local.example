# Supabase project URL — public, safe to commit.
NEXT_PUBLIC_SUPABASE_URL=https://bdmcxciktsjqonyxnnen.supabase.co

# Supabase anon (public) key — paste from the Supabase dashboard.
# Goes in .env.local (which is gitignored). Do NOT commit.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# DO NOT add SUPABASE_SERVICE_ROLE_KEY (or any service-role secret) to
# this file or to .env.local. The mobile app ships as a static bundle
# inside Capacitor — anything in process.env at build time gets baked
# into the JavaScript that's distributed to candidates' phones, where
# it can be inspected by anyone who unpacks the APK / IPA. Server-only
# operations (public lead intake, invitation-token verification,
# system jobs, HRMS handoff) live in apps/web; the mobile bundle MUST
# stay anon-key-only.
